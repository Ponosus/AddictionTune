<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="WindowBackground" Color="#1B1B1B"/>
    <SolidColorBrush x:Key="TextPrimary" Color="White"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#9A9A9A"/>
    <SolidColorBrush x:Key="MiniBarBackground" Color="#141414"/>

    <!-- На тёмной теме — белая иконка GitHub -->
    <BitmapImage x:Key="GithubIcon" UriSource="pack://application:,,,/Assets/github-white.png"/>

</ResourceDictionary>
