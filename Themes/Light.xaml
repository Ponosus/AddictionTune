<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="WindowBackground" Color="#F2F2F2"/>
    <SolidColorBrush x:Key="TextPrimary" Color="#111111"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#666666"/>
    <SolidColorBrush x:Key="MiniBarBackground" Color="#D9D9D9"/>

    <!-- На светлой теме — тёмная иконка GitHub -->
    <BitmapImage x:Key="GithubIcon" UriSource="pack://application:,,,/Assets/github.png"/>

</ResourceDictionary>
